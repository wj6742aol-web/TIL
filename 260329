<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>2048 간단 버전</title>
<style>
  body { text-align:center; font-family:sans-serif; }
  #board { 
    width: 200px; 
    margin: 20px auto; 
    display:grid; 
    grid-template-columns: repeat(4, 50px);
    gap:5px;
  }
  .cell {
    width:50px; height:50px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#ccc;
    font-weight:bold;
  }
</style>
</head>
<body>

<h1>2048</h1>
<div id="board"></div>

<script>
let board = Array(16).fill(0);

function draw() {
  const boardDiv = document.getElementById("board");
  boardDiv.innerHTML = "";
  board.forEach(v => {
    let cell = document.createElement("div");
    cell.className = "cell";
    cell.innerText = v === 0 ? "" : v;
    boardDiv.appendChild(cell);
  });
}

function randomSpawn() {
  let empty = board.map((v,i)=>v===0?i:null).filter(v=>v!==null);
  if(empty.length===0) return;
  let idx = empty[Math.floor(Math.random()*empty.length)];
  board[idx] = Math.random() < 0.9 ? 2 : 4;
}

function moveLeft() {
  for(let r=0;r<4;r++){
    let row = board.slice(r*4, r*4+4).filter(v=>v);
    for(let i=0;i<row.length-1;i++){
      if(row[i]===row[i+1]){
        row[i]*=2;
        row[i+1]=0;
      }
    }
    row = row.filter(v=>v);
    while(row.length<4) row.push(0);
    for(let i=0;i<4;i++) board[r*4+i]=row[i];
  }
  randomSpawn();
  draw();
}

document.addEventListener("keydown", e=>{
  if(e.key==="ArrowLeft") moveLeft();
});

randomSpawn();
randomSpawn();
draw();
</script>

</body>
</html>
