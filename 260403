import random

number = random.randint(1, 100)
attempts = 0

print("1부터 100 사이의 숫자를 맞춰보세요!")

while True:
    guess = int(input("숫자 입력: "))
    attempts += 1

    if guess < number:
        print("더 큽니다!")
    elif guess > number:
        print("더 작습니다!")
    else:
        print(f"정답! {attempts}번 만에 맞췄어요 🎉")
        break
