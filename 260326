<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>롤 5인큐 라인 룰렛</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      background: radial-gradient(circle at top, #1e293b, #020617);
      color: #e5e7eb;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .card {
      background: #020617;
      padding: 24px;
      border-radius: 24px;
      width: 400px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.8);
    }
    h1 {
      text-align: center;
      margin-bottom: 16px;
      font-size: 22px;
    }
    .players input {
      width: 100%;
      padding: 8px;
      margin-bottom: 8px;
      border-radius: 10px;
      border: none;
    }
    button {
      width: 100%;
      padding: 16px;
      margin-top: 14px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, #2563eb, #60a5fa);
      color: white;
      font-size: 18px;
      cursor: pointer;
      transition: transform 0.1s;
    }
    button:active { transform: scale(0.95); }

    .roulette {
      margin-top: 18px;
      background: #020617;
      border-radius: 16px;
      padding: 12px;
      height: 140px;
      overflow: hidden;
      position: relative;
      border: 1px solid #1e293b;
      text-align: center;
    }

    .slot {
      font-size: 20px;
      line-height: 32px;
      animation: shake 0.1s infinite;
    }

    @keyframes shake {
      0% { transform: translateX(0); }
      25% { transform: translateX(-2px); }
      50% { transform: translateX(2px); }
      75% { transform: translateX(-2px); }
      100% { transform: translateX(0); }
    }

    .final {
      margin-top: 16px;
      background: #020617;
      padding: 14px;
      border-radius: 14px;
      border: 1px solid #1e293b;
    }

    .final div {
      margin-bottom: 6px;
      font-size: 17px;
    }

    .boom {
      animation: boom 0.4s;
    }

    @keyframes boom {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }
  </style>
</head>
<body>
  <div class="card" id="card">
    <h1>🎰 롤 5인큐 미친 룰렛</h1>
    <div style="text-align:center; font-size:14px; font-weight:bold; color:#38bdf8; margin-bottom:12px;">✨ 딜아나 제작 ✨</div>

    <div class="players">
      <input placeholder="플레이어 1" />
      <input placeholder="플레이어 2" />
      <input placeholder="플레이어 3" />
      <input placeholder="플레이어 4" />
      <input placeholder="플레이어 5" />
    </div>

    <button onclick="spin()">🔥 운명을 돌려라</button>

    <div class="roulette">
      <div class="slot" id="slot">대기중...</div>
    </div>

    <div class="final" id="final"></div>
  </div>

  <script>
    const lanes = ["탑", "정글", "미드", "원딜", "서폿"];
    const sounds = {
      tick: new Audio('data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEAESsAACJWAAACABAAZGF0YQgAAAAA'),
    };

    let spinning = false;

    function shuffle(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    function spin() {
      if (spinning) return;
      spinning = true;

      const inputs = document.querySelectorAll('.players input');
      const names = Array.from(inputs).map(i => i.value || '이름없음');
      const result = shuffle([...lanes]);

      const slot = document.getElementById('slot');
      const finalDiv = document.getElementById('final');
      const card = document.getElementById('card');
      finalDiv.innerHTML = '';

      let count = 0;
      const max = 40 + Math.floor(Math.random() * 20);

      const interval = setInterval(() => {
        slot.innerHTML = shuffle([...lanes]).join('<br>');
        count++;

        if (count > max) {
          clearInterval(interval);
          slot.innerHTML = '💥 결정!';
          card.classList.add('boom');

          setTimeout(() => {
            slot.innerHTML = '';
            names.forEach((name, idx) => {
              const div = document.createElement('div');
              let text = `${name} → ${result[idx]}`;

              if (result[idx] === '서폿') {
                text += ' 💀';
              }

              div.textContent = text;
              finalDiv.appendChild(div);
            });
            spinning = false;
          }, 500);
        }
      }, 70);
    }
  </script>
</body>
</html>
